# Puerto del servidor (EasyPanel: 8080)
PORT=8080

# Postgres y Redis (en EasyPanel usa el host interno que te muestra cada servicio)
DATABASE_URL=postgres://postgres:CAMBIA_ESTO@marketplace-db:5432/marketplace
REDIS_URL=redis://marketplace-redis:6379

# Login del super-admin del panel
ADMIN_USER=admin
ADMIN_PASS=CAMBIA_ESTO

# URL pública de la app (SIN barra final). Necesaria para el OAuth y el SSO de GHL.
APP_BASE_URL=https://marketplace.tudominio.com

# Límite de peticiones por minuto y por API key en la API pública (opcional, def. 600)
API_RATE_PER_MIN=600

# --- Solo para docker-compose (autohospedaje/local) ---
POSTGRES_PASSWORD=cambia_esto
APP_PORT=8080
